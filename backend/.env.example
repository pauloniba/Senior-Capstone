PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/senior_capstone
# Used to sign user session tokens (JWT). In production this comes from SSM
# (/senior-capstone/JWT_SECRET). For local dev any non-empty string works.
JWT_SECRET=dev-only-change-me-locally
# Optional: model used by the HomeSense Agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
